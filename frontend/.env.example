# ============================================================================
# Zubchek — frontend environment variables
# Copy to `.env` (or set in your static host's build settings).
# ============================================================================

# Backend API origin (NO trailing slash).
# - Local dev: leave empty. The Vite dev server proxies /api -> localhost:8000.
# - Production: set to your backend URL, e.g. https://api.your-domain.com
VITE_API_BASE_URL=

# Optional branding / SEO overrides
VITE_APP_TITLE=Zubchek
VITE_APP_DESCRIPTION=AI dental hygiene analysis
