# Allow install when package.json and pnpm-lock.yaml are briefly out of sync
# (the Atoms/MGX deps were removed from package.json without regenerating the
# lockfile locally). Without this, pnpm defaults to --frozen-lockfile in CI
# (Cloudflare Pages) and fails the build on the mismatch. pnpm will prune the
# stale entries and update the lockfile during install.
frozen-lockfile=false
