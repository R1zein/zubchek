# ============================================================================
# Zubchek — backend environment variables
# Copy this file to `.env` and fill in real values.
# In docker-compose, DATABASE_URL and PORT are overridden automatically.
# ============================================================================

# --- Database (REQUIRED) ---------------------------------------------------
# Local docker-compose sets this for you. For managed Postgres (Neon/Supabase/
# Railway), paste the connection string here. Any of these drivers work — the
# app auto-normalizes to an async driver:
#   postgresql://user:pass@host:5432/dbname
#   postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=postgresql://zubchek:zubchek@localhost:5432/zubchek

# --- Server ----------------------------------------------------------------
PORT=8000
ENVIRONMENT=dev          # "dev" returns full stack traces; use "prod" in production
DEBUG=false

# --- URLs (used for OIDC redirects / CORS callbacks) -----------------------
FRONTEND_URL=http://localhost:3000
PYTHON_BACKEND_URL=http://localhost:8000

# --- AI provider (REQUIRED for teeth analysis) -----------------------------
# Any OpenAI-compatible endpoint: OpenAI, OpenRouter, or a proxy to Claude.
# Must support a VISION model for the photo analysis to work.
APP_AI_BASE_URL=https://api.openai.com/v1
APP_AI_KEY=sk-...

# --- Auth: app JWT (REQUIRED) ----------------------------------------------
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Auth: OIDC (OPTIONAL) -------------------------------------------------
# The frontend currently uses lightweight header auth (custom-auth), so OIDC
# is optional for beta. To enable "real" login, register the app with an
# identity provider (Auth0 / Clerk / Cognito / Keycloak) and fill these in.
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPE=openid email profile

# --- Bootstrap admin (OPTIONAL) --------------------------------------------
ADMIN_USER_ID=admin
ADMIN_USER_EMAIL=admin@example.com
# MGX_IGNORE_INIT_ADMIN=1   # set to skip auto-creating the admin user

# --- Payments (OPTIONAL — only if using Stripe) ----------------------------
STRIPE_SECRET_KEY=

# --- Object storage (OPTIONAL — the app stores photos in the DB, so this is
#     unused unless you re-enable the /api/v1/storage routes) ---------------
OSS_SERVICE_URL=
OSS_API_KEY=
