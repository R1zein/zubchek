# ============================================================================
# Zubchek — backend environment variables
# Copy this file to `.env` and fill in real values.
# In docker-compose, DATABASE_URL and PORT are overridden automatically.
# ============================================================================

# --- Database (REQUIRED) ---------------------------------------------------
# Local docker-compose sets this for you. For managed Postgres (Neon/Supabase/
# Railway), paste the connection string here. Any of these drivers work — the
# app auto-normalizes to an async driver:
#   postgresql://user:pass@host:5432/dbname
#   postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=postgresql://zubchek:zubchek@localhost:5432/zubchek

# --- Server ----------------------------------------------------------------
PORT=8000
ENVIRONMENT=dev          # "dev" returns full stack traces; use "prod" in production
DEBUG=false

# --- URLs (used for OIDC redirects / CORS callbacks) -----------------------
FRONTEND_URL=http://localhost:3000
PYTHON_BACKEND_URL=http://localhost:8000

# --- AI provider (REQUIRED for teeth analysis) -----------------------------
# Any OpenAI-compatible endpoint with a VISION model. Default is Claude via
# Anthropic's OpenAI-compatible endpoint. To use OpenAI/OpenRouter instead,
# swap all three values (and pick a vision model those providers serve).
APP_AI_BASE_URL=https://api.anthropic.com/v1
APP_AI_KEY=sk-ant-...
APP_AI_MODEL=claude-opus-4-8   # or claude-sonnet-5 (cheaper), claude-haiku-4-5

# Max photo analyses running at once. Extra requests queue (users keep seeing
# the "analyzing" spinner) instead of all spiking RAM together — lets a small
# 2 GB server stay safe. Bump to 3-4 after moving to a box with more RAM.
ANALYSIS_CONCURRENCY=2

# --- Auth: app JWT (REQUIRED) ----------------------------------------------
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Auth: OIDC (OPTIONAL) -------------------------------------------------
# The frontend currently uses lightweight header auth (custom-auth), so OIDC
# is optional for beta. To enable "real" login, register the app with an
# identity provider (Auth0 / Clerk / Cognito / Keycloak) and fill these in.
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPE=openid email profile

# --- Bootstrap admin (OPTIONAL) --------------------------------------------
ADMIN_USER_ID=admin
ADMIN_USER_EMAIL=admin@example.com
# MGX_IGNORE_INIT_ADMIN=1   # set to skip auto-creating the admin user

# --- Payments (OPTIONAL — only if using Stripe) ----------------------------
STRIPE_SECRET_KEY=

# --- Object storage for report photos (OPTIONAL but recommended) -----------
# When configured, report images are uploaded to the bucket and only their
# public URL is stored in the DB (keeps the DB small). If unset, photos stay
# base64 in the DB. Provider-agnostic S3 — use these for Yandex Object Storage:
S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=zubchek-photos
S3_PUBLIC_BASE_URL=          # e.g. https://zubchek-photos.storage.yandexcloud.net
#
# Legacy Cloudflare R2 vars (still accepted as a fallback if S3_* are unset):
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=zubchek-photos
# R2_PUBLIC_BASE_URL=

# --- Email (Resend) for verification codes & report delivery ---------------
# Doctor registration/login and patient login send one-time codes by email,
# and doctors can email report PDFs to patients. Set these in Railway.
# Without RESEND_API_KEY, emails are NOT sent — codes are logged instead so the
# flow stays testable during setup.
RESEND_API_KEY=            # Resend API key (starts with re_)
EMAIL_FROM=Zubchek <onboarding@resend.dev>   # switch to noreply@zubchek.com after verifying the domain

# --- Legacy MGX object storage (OPTIONAL, unused) --------------------------
OSS_SERVICE_URL=
OSS_API_KEY=
